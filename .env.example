# =============================================================================
# Heartbeat Monitor — Environment Configuration
# Copy this file to .env and fill in values for local development.
# In production (Kubernetes, ECS, etc.), inject these as environment variables.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# URLs to monitor — comma-separated list OR a JSON array.
# Examples:
#   MONITOR_URLS=https://example.com/health,https://api.example.com/health
#   MONITOR_URLS=["https://example.com/health","https://api.example.com/health"]
MONITOR_URLS=

# Slack incoming webhook URL. Required unless email is configured.
# Create one at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# ALERTING BEHAVIOR
# ---------------------------------------------------------------------------

# Seconds a target must be continuously failing before an alert fires.
# Default: 300 (5 minutes). Set lower (e.g. 60) for faster alerting,
# or higher (e.g. 600) to suppress transient blips entirely.
ALERT_AFTER_SECONDS=300

# How often to check each URL (seconds). Default: 60.
CHECK_INTERVAL_SECONDS=60

# Timeout for each HTTP request (seconds). Default: 30.
REQUEST_TIMEOUT_SECONDS=30

# Whether to send a recovery alert when a URL comes back up after a
# down-alert fired. Default: true.
SEND_RECOVERY_ALERTS=true

# ---------------------------------------------------------------------------
# EMAIL ALERTS (optional — all fields required together to enable)
# ---------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
# Comma-separated list of recipients
EMAIL_TO=
